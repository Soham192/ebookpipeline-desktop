{
  "name": "kindle-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@tauri-apps/plugin-shell": "^2.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
