# Example environment variables for Universal E-Reader Agent (local production)

# SMTP settings (required for Kindle delivery)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=sender@example.com
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# Backend settings
# Set to 0.0.0.0 to listen on all interfaces in production
HOST=127.0.0.1
PORT=8000

# Optional: frontend origin for CORS (if serving separately)
FRONTEND_ORIGIN=http://localhost:3001

# Local dev convenience: copy to .env for quick startup
# cp .env.example .env

# Note: Do NOT commit a real backend/.env with secrets to git.
# Copy this file to backend/.env and fill in production values before running.
